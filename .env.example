# .env — SECRETS and machine-specific overrides only.
# Non-secret settings (port, public_url, human_name, max_ai_turns, cleanup, …)
# live in config.yaml now. See config.yaml.example.

# Web dashboard login. The password is sensitive — keep it here, not in config.yaml.
# Seeds the user on first run; if set, it is synced on every restart.
# Defaults: stoa@stoa.com / stoa2026!
# STOA_EMAIL=you@example.com
# STOA_PASSWORD=change-me

# Optional infra overrides (resolved by paths.js from the real environment, not config.yaml):
# STOA_DEV=1            # force development mode (data in the repo) — default in a git checkout
# STOA_DEV=0            # force installed mode (data in ~/.stoa/server)
# STOA_HOME=~/.stoa     # base dir for installed data (default ~/.stoa)
# STOA_DATA_DIR=/absolute/server/data/dir   # exact server data dir (overrides STOA_HOME)
# DB_PATH=/absolute/path/to/stoa.db         # database file only

# Non-secret settings live in config.yaml (see config.yaml.example). For backward
# compatibility these are still honored as env overrides if set here:
#   PORT, STOA_PUBLIC_URL, HUMAN_NAME, MAX_AI_TURNS, MAX_CONCURRENT,
#   SESSION_IDLE_TTL, AUTO_COMPACT_THRESHOLD_KB, CLEANUP_CRON_HOUR, CLEANUP_MAX_AGE_HOURS
# Prefer editing config.yaml (or Settings in the web UI) instead.

# Agent credentials (STOA_URL, STOA_ACTOR_ID, STOA_SECRET, STOA_AI_BACKEND, …) are NOT
# set here — the installer writes them into each agent's own service unit.
