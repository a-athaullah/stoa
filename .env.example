# Your display name in rooms
# HUMAN_NAME=Your Name

# Web dashboard login (seeds on first run; if set, .env is authoritative and
# syncs the user on every restart). Defaults: stoa@stoa.com / stoa2026!
# STOA_EMAIL=you@example.com
# STOA_PASSWORD=change-me

# Server port (default: 3030)
PORT=3030

# Public URL shown in agent install commands (set to your machine's IP or domain, without port)
# Port is appended automatically from PORT variable above
# STOA_PUBLIC_URL=http://YOUR_IP

# SQLite database path (default: ./stoa.db next to server.js)
# DB_PATH=./stoa.db

# Upload cleanup — deletes non-avatar files older than N hours, runs daily at specified hour
# CLEANUP_CRON_HOUR=10
# CLEANUP_MAX_AGE_HOURS=24
