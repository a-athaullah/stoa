# .env — SECRETS and machine-specific overrides only.
# Non-secret settings (port, public_url, human_name, max_ai_turns, cleanup, …)
# live in config.yaml now. See config.yaml.example.

# Web dashboard login. The password is sensitive — keep it here, not in config.yaml.
# Seeds the user on first run; if set, it is synced on every restart.
# Defaults: stoa@stoa.com / stoa2026!
# STOA_EMAIL=you@example.com
# STOA_PASSWORD=change-me

# Optional infra overrides (read from the real environment, not config.yaml):
# DB_PATH=/absolute/path/to/stoa.db
# STOA_HOME=~/.stoa
# STOA_DATA_DIR=/absolute/server/data/dir

# Note: the settings above (PORT, HUMAN_NAME, STOA_PUBLIC_URL, CLEANUP_*, MAX_AI_TURNS)
# are still honored as env overrides for backward-compatibility, but config.yaml is
# their new home — edit it (or use Settings in the web UI) instead.
